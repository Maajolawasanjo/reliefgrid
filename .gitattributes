# Set default behavior to handle line endings automatically
* text=auto eol=lf

# Explicit text files requiring LF
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
*.woff2 binary

# GitHub Linguist Overrides
docs/* linguist-documentation
apps/api/* linguist-language=Python
apps/web/* linguist-language=TypeScript
