# ReliefGrid Master Environment Configuration Template
# Copy to .env in backend (apps/api) or environment dashboard on Vercel/Railway

# ── API & Core Server Settings ─────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
API_V1_STR=/api/v1
PROJECT_NAME="ReliefGrid Emergency Intelligence System"
HOST=0.0.0.0
PORT=8000

# ── Security & Authentication ─────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-256-bit-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000","https://reliefgrid.vercel.app","https://*.railway.app"]

# ── CockroachDB Database Configuration ───────────────────────────────
DATABASE_URL=postgresql://root@localhost:26257/reliefgrid?sslmode=disable
# For Production CockroachDB Serverless / Managed:
# DATABASE_URL=postgresql://<user>:<password>@<cluster-host>.cockroachlabs.cloud:26257/reliefgrid?sslmode=verify-full

# ── AWS Bedrock & Vector Embedding Credentials ────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Weather & External GIS Feeds ──────────────────────────────────────
OPEN_METEO_API_URL=https://api.open-meteo.com/v1/forecast
NOMINATIM_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
OSRM_ROUTING_URL=http://router.project-osrm.org/route/v1/driving

# ── Frontend Next.js Public Settings ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_TITLE="ReliefGrid Emergency Intelligence System"
